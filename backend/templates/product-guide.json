{
  "type": "template",
  "name": "Product Guide",
  "description": "A product guide template with overview, features, and usage instructions",
  "version": "1.0",
  "dataSources": [
    {
      "id": "product_data",
      "name": "Product Information",
      "pythonInterface": "data_sources::fetch_product_data",
      "parameters": {
        "product_id": "example_product"
      }
    }
  ],
  "chapters": [
    {
      "id": "overview",
      "title": "Product Overview",
      "dataSourceId": "product_data",
      "prompt": "prompts/product-guide/overview.md",
      "status": "pending"
    },
    {
      "id": "features",
      "title": "Key Features",
      "dataSourceId": "product_data",
      "prompt": "prompts/product-guide/features.md",
      "status": "pending"
    },
    {
      "id": "usage",
      "title": "Getting Started",
      "dataSourceId": "product_data",
      "prompt": "prompts/product-guide/usage.md",
      "status": "pending"
    }
  ],
  "document": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": { "level": 1 },
        "content": [{ "type": "text", "text": "Product Guide" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "overview" },
        "content": [{ "type": "text", "text": "Overview" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "overview" },
        "content": [{ "type": "text", "text": "[Generate overview]" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "features" },
        "content": [{ "type": "text", "text": "Key Features" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "features" },
        "content": [{ "type": "text", "text": "[Generate features]" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "usage" },
        "content": [{ "type": "text", "text": "Getting Started" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "usage" },
        "content": [{ "type": "text", "text": "[Generate usage instructions]" }]
      }
    ]
  }
}
