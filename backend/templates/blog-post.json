{
  "type": "template",
  "name": "Blog Post",
  "description": "A simple blog post template with introduction and conclusion",
  "version": "1.0",
  "dataSources": [
    {
      "id": "webpage",
      "name": "Webpage Content",
      "pythonInterface": "data_sources.web::fetch_html_content",
      "parameters": {
        "url": "https://www.anthropic.com/research/labor-market-impacts"
      }
    }
  ],
  "chapters": [
    {
      "id": "intro",
      "title": "Introduction",
      "dataSourceId": "webpage",
      "prompt": "prompts/blog-post/introduction.md",
      "status": "pending"
    },
    {
      "id": "body",
      "title": "Main Content",
      "dataSourceId": "webpage",
      "prompt": "prompts/blog-post/body.md",
      "status": "pending"
    },
    {
      "id": "conclusion",
      "title": "Conclusion",
      "dataSourceId": "webpage",
      "prompt": "prompts/blog-post/conclusion.md",
      "status": "pending"
    }
  ],
  "document": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": { "level": 1 },
        "content": [{ "type": "text", "text": "Blog Post" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "intro" },
        "content": [{ "type": "text", "text": "Introduction" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "intro" },
        "content": [{ "type": "text", "text": "[Generate introduction]" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "body" },
        "content": [{ "type": "text", "text": "Main Content" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "body" },
        "content": [{ "type": "text", "text": "[Generate main content]" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 2, "chapterId": "conclusion" },
        "content": [{ "type": "text", "text": "Conclusion" }]
      },
      {
        "type": "paragraph",
        "attrs": { "chapterId": "conclusion" },
        "content": [{ "type": "text", "text": "[Generate conclusion]" }]
      }
    ]
  }
}
